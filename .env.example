# URL the FRONTEND uses for SERVER-SIDE fetches (SSR rendering /p/<slug>).
# In production we point this at the local backend over loopback for speed.
# In local dev, point at the backend dev port (3000).
# When forking this repo, set this to https://append.page or your own backend.
APPEND_PAGE_API_URL=http://127.0.0.1:38080

# Public URL of the site (used for canonical links, og tags, etc.).
NEXT_PUBLIC_BASE_URL=https://append.page
